<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Resume of Mayank M B" />
  <title>Mayank M B — Resume</title>
  <style>
    :root {
      --ink: #17212b;
      --muted: #687580;
      --line: #dce4e8;
      --accent: #0f766e;
      --accent-soft: #e7f4f2;
      --paper: #ffffff;
      --canvas: #eef2f4;
    }

    * { box-sizing: border-box; }

    html { background: var(--canvas); }

    body {
      margin: 0;
      background: var(--canvas);
      color: var(--ink);
      font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI",
        Roboto, Helvetica, Arial, sans-serif;
      font-size: 13px;
      line-height: 1.38;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .resume {
      width: min(100%, 210mm);
      min-height: 297mm;
      margin: 28px auto;
      padding: 14mm 15mm 12mm;
      overflow: hidden;
      background: var(--paper);
      box-shadow: 0 18px 55px rgba(23, 33, 43, 0.12);
    }

    .hero {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 26px;
      padding-bottom: 17px;
      border-bottom: 1px solid var(--line);
    }

    .intro {
      min-width: 0;
      flex: 1 1 auto;
    }

    .eyebrow {
      margin: 0 0 6px;
      color: var(--accent);
      font-size: 10px;
      font-weight: 850;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: 35px;
      line-height: 1;
      letter-spacing: -0.045em;
    }

    .headline {
      max-width: 570px;
      margin: 9px 0 0;
      font-size: 14px;
      font-weight: 680;
      line-height: 1.32;
    }

    .focus {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 11.5px;
      font-weight: 650;
    }

    .contact {
      width: 255px;
      flex: 0 0 255px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      color: var(--muted);
      font-size: 10.5px;
      font-style: normal;
      text-align: right;
      overflow-wrap: anywhere;
    }

    .contact a:hover { color: var(--accent); }

    .layout {
      display: flex;
      align-items: flex-start;
      gap: 25px;
      padding-top: 18px;
    }

    .main {
      min-width: 0;
      flex: 1 1 auto;
    }

    .sidebar {
      width: 190px;
      flex: 0 0 190px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 9px;
      margin: 0 0 12px;
      font-size: 10.5px;
      font-weight: 850;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .section-title::after {
      content: "";
      height: 1px;
      flex: 1;
      background: var(--line);
    }

    .experience-list {
      display: flex;
      flex-direction: column;
      gap: 9px;
    }

    .role {
      position: relative;
      padding: 0 0 0 13px;
      border-left: 2px solid var(--accent-soft);
      break-inside: avoid;
    }

    .role::before {
      content: "";
      position: absolute;
      left: -4px;
      top: 5px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
    }

    .role-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
    }

    .role h3 {
      min-width: 0;
      margin: 0;
      font-size: 12.4px;
      line-height: 1.22;
      letter-spacing: -0.008em;
    }

    .company {
      color: var(--accent);
      font-weight: 820;
    }

    .date {
      flex: 0 0 auto;
      color: var(--muted);
      font-size: 9.3px;
      font-weight: 780;
      letter-spacing: 0.025em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .location {
      margin-top: 2px;
      color: var(--muted);
      font-size: 9.6px;
    }

    .achievements {
      display: flex;
      flex-wrap: wrap;
      gap: 2px 12px;
      margin: 5px 0 0;
      padding: 0;
      color: #36434d;
      font-size: 9.8px;
      list-style: none;
    }

    .achievements li {
      position: relative;
      width: calc(50% - 6px);
      padding-left: 10px;
    }

    .achievements li::before {
      content: "—";
      position: absolute;
      left: 0;
      color: var(--accent);
      font-weight: 850;
    }

    .card {
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: linear-gradient(180deg, #ffffff 0%, #fbfcfd 100%);
      break-inside: avoid;
    }

    .card .section-title {
      margin-bottom: 10px;
    }

    .card .section-title::after {
      display: none;
    }

    .skill-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .skill-list li {
      padding: 5px 8px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: #155f59;
      font-size: 9.6px;
      font-weight: 750;
      line-height: 1.18;
    }

    .education-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .education-item h3 {
      margin: 0;
      font-size: 11.2px;
      line-height: 1.28;
    }

    .education-item p {
      margin: 3px 0 0;
      color: var(--muted);
      font-size: 9.5px;
      font-weight: 650;
    }

    .location-card {
      padding: 14px;
      border-radius: 13px;
      background: var(--ink);
      color: white;
      break-inside: avoid;
    }

    .location-label {
      margin: 0 0 4px;
      color: #b9c7ce;
      font-size: 8.8px;
      font-weight: 850;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .location-value {
      margin: 0;
      font-size: 11px;
      font-weight: 750;
    }

    @media (max-width: 760px) {
      .resume {
        width: 100%;
        min-height: auto;
        margin: 0;
        padding: 28px 22px;
        box-shadow: none;
      }

      .hero,
      .layout {
        flex-direction: column;
        align-items: stretch;
      }

      .contact,
      .sidebar {
        width: auto;
        flex-basis: auto;
      }

      .contact {
        text-align: left;
      }

      .role-head {
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
      }

      .achievements li {
        width: 100%;
      }
    }

    @page {
      size: A4;
      margin: 0;
    }

    @media print {
      html,
      body {
        width: 210mm;
        height: 297mm;
        background: #ffffff;
      }

      body {
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }

      .resume {
        width: 210mm;
        height: 297mm;
        min-height: 297mm;
        margin: 0;
        padding: 12mm 14mm 10mm;
        box-shadow: none;
        page-break-after: avoid;
      }

      .hero { padding-bottom: 15px; }
      .layout { gap: 22px; padding-top: 16px; }
      .sidebar { width: 183px; flex-basis: 183px; gap: 14px; }
      .experience-list { gap: 8px; }
      .role h3 { font-size: 11.9px; }
      .achievements { font-size: 9.4px; }
    }
  </style>
</head>
